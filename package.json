{
  "name": "playwright-ts-automation-framework",
  "version": "1.0.0",
  "description": "Robust layered test automation framework with Playwright + TypeScript",
  "scripts": {
    "test": "playwright test",
    "test:chrome": "playwright test --project=chromium",
    "test:firefox": "playwright test --project=firefox",
    "test:linkedin": "playwright test tests/linkedin/",
    "test:smoke": "playwright test tests/smoke/",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:ui": "playwright test --ui",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "allure:serve": "allure serve allure-results",
    "report": "playwright show-report playwright-report",
    "lint": "eslint src tests --ext .ts",
    "lint:fix": "eslint src tests --ext .ts --fix",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf allure-results allure-report test-results playwright-report reports/pdf reports/screenshots",
    "install:browsers": "playwright install chromium firefox",
    "ai:generate": "python ai_pipeline/main.py",
    "ai:generate:single": "python ai_pipeline/main.py --scenario",
    "ai:generate:dry": "python ai_pipeline/main.py --dry-run",
    "ai:setup": "pip install -r ai_pipeline/requirements.txt"
  },
  "dependencies": {
    "dotenv": "^16.3.1",
    "pdfkit": "^0.14.0",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^4.7.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.42.0",
    "@types/node": "^20.11.0",
    "@types/pdfkit": "^0.13.3",
    "allure-playwright": "^3.0.0",
    "allure-js-commons": "^3.0.0",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "rimraf": "^5.0.5",
    "typescript": "^5.3.3"
  }
}
